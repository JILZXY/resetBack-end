  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Adicto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const data = response.data || response;",
                  "if (data && data.accessToken) {",
                  "    pm.collectionVariables.set(\"token\", data.accessToken);",
                  "}",
                  "if (data && data.user && data.user.id) {",
                  "    pm.collectionVariables.set(\"addict_id\", data.user.id);",
                  "} else if (data && data.id) {",
                  "    pm.collectionVariables.set(\"addict_id\", data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paciente Demo\",\n  \"email\": \"paciente_demo@reset.com\",\n  \"password\": \"qwerty1234\",\n  \"role\": \"ADICTO\",\n  \"addictionName\": \"Alcohol\",\n  \"classification\": \"Sustancia\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
